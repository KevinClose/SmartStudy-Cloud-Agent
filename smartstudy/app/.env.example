# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=smartstudy
MONGODB_CONTEXT_COLLECTION=documents
MONGODB_HISTORY_COLLECTION=chat_history
MONGODB_VECTOR_INDEX=vector_index

# Vertex AI / Gemini
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCS_BUCKET_NAME=smartstudy-pdfs-smartstudy-infoh505
EMBEDDING_MODEL=text-embedding-005
LLM_MODEL=gemini-2.5-flash

# Local development only
# Path is relative to where you launch `streamlit run app/app.py` (the project root).
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json